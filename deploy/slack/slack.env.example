# MaKlaude Slack configuration — example.
#
# Copy to a local, GITIGNORED file (e.g. .env.slack.local), fill in real values,
# and `set -a; source .env.slack.local; set +a` before running MaKlaude or the
# live Slack test. NEVER commit real tokens. See docs/slack.md.
#
# Tokens come from a Slack app created via deploy/slack/manifest.yaml; the channel
# ID comes from deploy/slack/setup.sh.

# Bot User OAuth Token (xoxb-…) — outbound Web API posts.  REQUIRED. Secret.
export MAKLAUDE_SLACK_BOT_TOKEN="xoxb-REPLACE-ME"

# App-Level Token (xapp-…, scope connections:write) — Socket Mode inbound.  REQUIRED. Secret.
export MAKLAUDE_SLACK_APP_TOKEN="xapp-REPLACE-ME"

# Target channel for escalation threads — channel ID (preferred) or #name.  REQUIRED.
export MAKLAUDE_SLACK_CHANNEL="C0XXXXXXXXX"

# Operator to @-mention on needs:human escalations (mobile push).  OPTIONAL.
# Slack user ID (U…), user-group ID (S…), or a literal <…> mention token.
export MAKLAUDE_SLACK_OPERATOR="U0XXXXXXXXX"

# Signing secret — ONLY needed if you run the optional HTTP Events API mode
# instead of the default Socket Mode.  OPTIONAL. Secret.
# export MAKLAUDE_SLACK_SIGNING_SECRET="REPLACE-ME"
